# Copy to .env and set the values for your environment

# Sync Version (used by Alembic migrations)
DATABASE_MIGRATION_URL="mssql+pyodbc://<username>:<password>@<host>:1433/<database>?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes&LongAsMax=Yes"

# Async Version (used by the application at runtime)
DATABASE_URL="mssql+aioodbc://<username>:<password>@<host>:1433/<database>?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes&LongAsMax=Yes"

# Authentication (JWT tokens issued by the Identity Service)
SECRET_TOKEN_KEY=<i.e. openssl rand -hex 32>
AUTH_ALGORITHM=<The algorithm to use, for instance: HS256>
TOKEN_TIME_DELTA_IN_MINUTES=<INT>
TOKEN_URL=<The token URL, for instance: /token>

# Service identity (must match the service registration in the Identity Service)
SERVICE_ID=<UUID of this service>
SERVICE_NAME=<name of this service, e.g. my-service>

# Logging & CORS
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*

# Azure Monitor (Application Insights) - optional
# When set, logs, traces, and metrics are sent to Azure Monitor
# Get from Azure Portal: Application Insights resource -> Overview -> Connection string
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Enable/disable Azure observability signals (default: true when connection string is set)
# AZURE_LOGGING_ENABLED=true
# AZURE_TRACING_ENABLED=true
# AZURE_METRICS_ENABLED=true

# Logging
# MIN_LOG_LEVEL_FOR_AZURE=INFO
# AZURE_LOG_BATCH_DELAY_MILLIS=60000

# Tracing
# TRACE_SAMPLE_RATE=1.0
# ENABLE_TRACE_CONSOLE_EXPORT=false

# Metrics export interval (seconds)
METRICS_COLLECTION_INTERVAL=60
